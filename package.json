{
  "name": "convex-conflict-free-counter",
  "description": "An eventually-consistent, contention-free counter component for Convex.",
  "repository": "github:stack1ng/convex-conflict-free-counter",
  "homepage": "https://github.com/stack1ng/convex-conflict-free-counter#readme",
  "bugs": {
    "url": "https://github.com/stack1ng/convex-conflict-free-counter/issues"
  },
  "version": "1.0.1",
  "license": "Apache-2.0",
  "keywords": [
    "convex",
    "component",
    "counter",
    "count",
    "metrics",
    "eventually-consistent"
  ],
  "type": "module",
  "scripts": {
    "dev": "convex dev --start 'npm run dev:build'",
    "dev:build": "chokidar 'tsconfig*.json' 'src/**/*.ts' -i '**/*.test.ts' -c 'npm run build:codegen' --initial",
    "predev": "convex init && npm run build:codegen",
    "build": "tsc --project ./tsconfig.build.json",
    "build:codegen": "npx convex codegen --component-dir ./src/component && npm run build",
    "build:clean": "rm -rf dist *.tsbuildinfo && npm run build:codegen",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit && tsc -p example/convex",
    "lint": "eslint .",
    "test": "vitest run --typecheck",
    "test:watch": "vitest --typecheck --clearScreen false",
    "test:debug": "vitest --inspect-brk --no-file-parallelism",
    "test:coverage": "vitest run --coverage --coverage.reporter=text",
    "prepare": "npm run build",
    "preversion": "npm ci && npm run clean && npm run build && npm run test && npm run lint && npm run typecheck",
    "alpha": "npm version prerelease --preid alpha && git push --follow-tags",
    "release": "node scripts/release.mjs",
    "version": "node scripts/changelog.mjs && prettier -w CHANGELOG.md && git add CHANGELOG.md"
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./test": "./src/test.ts",
    "./_generated/component.js": {
      "types": "./dist/component/_generated/component.d.ts",
      "default": "./dist/component/_generated/component.js"
    },
    "./_generated/component": {
      "types": "./dist/component/_generated/component.d.ts",
      "default": "./dist/component/_generated/component.js"
    },
    "./convex.config.js": {
      "types": "./dist/component/convex.config.d.ts",
      "default": "./dist/component/convex.config.js"
    },
    "./convex.config": {
      "types": "./dist/component/convex.config.d.ts",
      "default": "./dist/component/convex.config.js"
    }
  },
  "dependencies": {
    "convex-helpers": "^0.1.104"
  },
  "peerDependencies": {
    "convex": "^1.36.1"
  },
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^2.0.0",
    "@edge-runtime/vm": "^5.0.0",
    "@eslint/js": "^9.39.4",
    "@fast-check/vitest": "^0.4.0",
    "@types/node": "^24.12.2",
    "chokidar-cli": "3.0.0",
    "convex": "^1.42.0",
    "convex-test": "^0.0.49",
    "eslint": "^9.39.4",
    "globals": "^17.5.0",
    "prettier": "3.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  },
  "types": "./dist/client/index.d.ts",
  "module": "./dist/client/index.js"
}
